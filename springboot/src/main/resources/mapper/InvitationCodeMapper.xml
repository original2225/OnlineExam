<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.example.mapper.InvitationCodeMapper">

    <resultMap id="BaseResultMap" type="com.example.entity.InvitationCode">
        <id column="id" property="id"/>
        <result column="code" property="code"/>
        <result column="status" property="status"/>
        <result column="used_by" property="usedBy"/>
        <result column="used_by_username" property="usedByUsername"/>
        <result column="used_time" property="usedTime"/>
        <result column="create_time" property="createTime"/>
        <result column="created_by" property="createdBy"/>
        <result column="expire_time" property="expireTime"/>
        <result column="remark" property="remark"/>
        <result column="target_role" property="targetRole"/>
    </resultMap>

    <insert id="insert" parameterType="com.example.entity.InvitationCode" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO invitation_code (code, status, create_time, created_by, expire_time, remark, target_role)
        VALUES (#{code}, #{status}, #{createTime}, #{createdBy}, #{expireTime}, #{remark}, #{targetRole})
    </insert>

    <insert id="batchInsert">
        INSERT INTO invitation_code (code, status, create_time, created_by, expire_time, remark, target_role)
        VALUES
        <foreach collection="list" item="item" separator=",">
            (#{item.code}, #{item.status}, #{item.createTime}, #{item.createdBy}, #{item.expireTime}, #{item.remark}, #{item.targetRole})
        </foreach>
    </insert>

    <select id="selectById" resultMap="BaseResultMap">
        SELECT * FROM invitation_code WHERE id = #{id}
    </select>

    <select id="selectByCode" resultMap="BaseResultMap">
        SELECT * FROM invitation_code WHERE code = #{code}
    </select>

    <select id="selectAll" resultMap="BaseResultMap">
        SELECT * FROM invitation_code
        <where>
            <if test="status != null and status != ''">
                AND status = #{status}
            </if>
            <if test="code != null and code != ''">
                AND code LIKE CONCAT('%', #{code}, '%')
            </if>
            <if test="targetRole != null and targetRole != ''">
                AND target_role = #{targetRole}
            </if>
        </where>
        ORDER BY create_time DESC
    </select>

    <update id="updateToUsed">
        UPDATE invitation_code
        SET status = 'USED',
            used_by = #{usedBy},
            used_by_username = #{usedByUsername},
            used_time = #{usedTime}
        WHERE id = #{id}
    </update>

    <delete id="deleteById">
        DELETE FROM invitation_code WHERE id = #{id}
    </delete>

    <delete id="deleteBatch">
        DELETE FROM invitation_code WHERE id IN
        <foreach collection="ids" item="id" open="(" separator="," close=")">
            #{id}
        </foreach>
    </delete>

    <delete id="deleteAllUnused">
        DELETE FROM invitation_code WHERE status = 'UNUSED'
    </delete>

</mapper>
