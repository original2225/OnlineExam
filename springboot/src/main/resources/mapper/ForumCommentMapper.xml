<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.example.mapper.ForumCommentMapper">

    <select id="selectByPostId" resultType="com.example.entity.ForumComment">
        select * from `forum_comment`
        where post_id = #{postId} and status = 'active'
        order by created_at asc
    </select>

    <insert id="insert" parameterType="com.example.entity.ForumComment" useGeneratedKeys="true">
        insert into `forum_comment`
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="postId != null">post_id,</if>
            <if test="content != null">content,</if>
            <if test="authorId != null">author_id,</if>
            <if test="authorName != null">author_name,</if>
            <if test="authorRole != null">author_role,</if>
            <if test="authorAvatar != null">author_avatar,</if>
            <if test="parentId != null">parent_id,</if>
        </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="postId != null">#{postId},</if>
            <if test="content != null">#{content},</if>
            <if test="authorId != null">#{authorId},</if>
            <if test="authorName != null">#{authorName},</if>
            <if test="authorRole != null">#{authorRole},</if>
            <if test="authorAvatar != null">#{authorAvatar},</if>
            <if test="parentId != null">#{parentId},</if>
        </trim>
    </insert>

    <delete id="deleteById">
        update `forum_comment` set status = 'deleted' where id = #{id}
    </delete>

</mapper>
