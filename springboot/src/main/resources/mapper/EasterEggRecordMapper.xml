<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.example.mapper.EasterEggRecordMapper">

    <insert id="insert" parameterType="com.example.entity.EasterEggRecord" useGeneratedKeys="true">
        insert into `easter_egg_record`
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="id != null">id,</if>
            <if test="userId != null">user_id,</if>
            <if test="userName != null">user_name,</if>
            <if test="userRole != null">user_role,</if>
            <if test="eggName != null">egg_name,</if>
            <if test="discoverTime != null">discover_time,</if>
        </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="id != null">#{id},</if>
            <if test="userId != null">#{userId},</if>
            <if test="userName != null">#{userName},</if>
            <if test="userRole != null">#{userRole},</if>
            <if test="eggName != null">#{eggName},</if>
            <if test="discoverTime != null">#{discoverTime},</if>
        </trim>
    </insert>

    <select id="selectByUserAndRoleAndEgg" resultType="com.example.entity.EasterEggRecord">
        select * from `easter_egg_record`
        where user_id = #{userId} and user_role = #{userRole} and egg_name = #{eggName}
    </select>

    <select id="selectByEggName" resultType="com.example.entity.EasterEggRecord">
        select * from `easter_egg_record`
        where egg_name = #{eggName}
        order by discover_time asc
    </select>

    <select id="selectLeaderboard" resultType="com.example.entity.EasterEggRecord">
        select * from `easter_egg_record`
        order by discover_time asc
    </select>

    <select id="selectCountByEggName" resultType="int">
        select count(*) from `easter_egg_record` where egg_name = #{eggName}
    </select>

    <select id="selectAllEggsByUser" resultType="com.example.entity.EasterEggRecord">
        select * from `easter_egg_record`
        where user_id = #{userId} and user_role = #{userRole}
        order by discover_time asc
    </select>

</mapper>
