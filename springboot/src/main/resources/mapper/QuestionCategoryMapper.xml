<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.example.mapper.QuestionCategoryMapper">

    <select id="selectAll" resultType="com.example.entity.QuestionCategory">
        select * from `question_category`
        <where>
            <if test="name != null"> and name like concat('%', #{name}, '%')</if>
            <if test="status != null"> and status = #{status}</if>
            <if test="parentId != null"> and parent_id = #{parentId}</if>
        </where>
        order by id asc
    </select>

    <select id="selectByParentId" resultType="com.example.entity.QuestionCategory">
        select * from `question_category`
        where parent_id = #{parentId}
        order by id asc
    </select>

    <delete id="deleteById">
        delete from `question_category`
        where id = #{id}
    </delete>

    <insert id="insert" parameterType="com.example.entity.QuestionCategory" useGeneratedKeys="true">
        insert into `question_category`
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="id != null">id,</if>
            <if test="name != null">name,</if>
            <if test="description != null">description,</if>
            <if test="status != null">status,</if>
            <if test="parentId != null">parent_id,</if>
            <if test="icon != null">icon,</if>
        </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="id != null">#{id},</if>
            <if test="name != null">#{name},</if>
            <if test="description != null">#{description},</if>
            <if test="status != null">#{status},</if>
            <if test="parentId != null">#{parentId},</if>
            <if test="icon != null">#{icon},</if>
        </trim>
    </insert>

    <update id="updateById" parameterType="com.example.entity.QuestionCategory">
        update `question_category`
        <set>
            <if test="name != null">
                name = #{name},
            </if>
            <if test="description != null">
                description = #{description},
            </if>
            <if test="status != null">
                status = #{status},
            </if>
            parent_id = #{parentId},
            icon = #{icon},
        </set>
        where id = #{id}
    </update>

</mapper>
